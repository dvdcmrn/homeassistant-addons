# Local troubleshooting and example files (may contain private HA config)
local/

# Secrets and credentials — never commit
.env
.env.*
*.secrets
*.secret
secrets.yaml
**/secrets.yaml
**/*.pem
**/*.key
**/authorized_keys
**/*_rsa
**/*_ed25519

# OS files
.DS_Store
*.swp
*.swo
*~

# Python cache
__pycache__/
*.pyc
*.pyo

# Editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
